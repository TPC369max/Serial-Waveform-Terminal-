<Window x:Class="Yell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Yell"
        xmlns:ScottPlot="clr-namespace:ScottPlot;assembly=ScottPlot.WPF" 
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="600">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <GroupBox Header="串口参数配置" Margin="10" Padding="5">
            <StackPanel>
                <!-- 校验位 -->
                <DockPanel Margin="5">
                    <TextBlock Text="校验位：" Width="80" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding ParityMap.Keys}" SelectedItem="{Binding SelectedParityKey}" />
                </DockPanel>

                <!-- 停止位 -->
                <DockPanel Margin="5">
                    <TextBlock Text="停止位：" Width="80" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding StopBitsMap.Keys}" SelectedItem="{Binding SelectedStopBitsKey}" />
                </DockPanel>
                <DockPanel>
                    <TextBlock Text="选串口：" Width="80" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailablePorts}" 
          SelectedItem="{Binding SelectedPort}" 
          Width="100"/>
                </DockPanel>
                <DockPanel>
                    <Button Content="打开串口" 
Command="{Binding StartConnectCommand}" 
Height="30" 
Width="100" 
Margin="0,20,0,0" 
HorizontalAlignment="Left"/>
                    <Button Content="发送" Command="{Binding ExecuteSendCommand}" Height="30" 
Width="100" 
Margin="0,20,0,0" />
                    <Button Content="清空测试" 
Command="{Binding ClearDataCommand}" 
Background="LightBlue" 
Margin="5"/>
                </DockPanel>
                <DockPanel>
                    <TextBox x:Name="txtIn" Text="{Binding InputHexText}"></TextBox>
                </DockPanel>
                <DockPanel>
                    <Button Content="开始波形仿真" 
        Command="{Binding RunSimulationCommand}" 
        Background="LightBlue" 
        Margin="5"/>
                    <ScottPlot:WpfPlot x:Name="RealTimePlot" Height="200" Width="400" Margin="10"/>
                    <Button Content="导出CSV" 
Command="{Binding ExportDataCommand}" 
Background="LightBlue" 
Margin="5"/>
                </DockPanel>
                <CheckBox x:Name="AutoScrollCheckBox" 
              Content="自动滚动" 
              IsChecked="True" 
              VerticalAlignment="Center" 
              Margin="0,0,10,0"/>
                <!-- 替换你原来的 TextBox -->
                <ListBox x:Name="LogListBox" ItemsSource="{Binding Logs}" Height="200" Background="#F5F5F5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- 使用横向布局排列日志的每一项 -->
                            <StackPanel Orientation="Horizontal">
                                <!-- 时间显示为灰色 -->
                                <TextBlock Text="{Binding Time}" Foreground="Gray" Width="100"/>
                                <!-- 类型根据发送/接收显示不同颜色 (进阶功能，目前先统一) -->
                                <TextBlock Text="{Binding Direction}" FontWeight="Bold" Width="50" Margin="5,0"/>
                                <!-- 日志正文 -->
                                <TextBlock Text="{Binding RawData}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Value}" Margin="5,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
